APP_NAME=NLP Platform
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/nlp_platform
SECRET_KEY=generate-a-random-64-char-hex-string

# Firebase Storage (optional — leave empty to use local file storage)
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Local audio storage directory (relative to backend/)
LOCAL_AUDIO_DIR=uploads/audio

# Verification thresholds
VERIFICATION_APPROVAL_THRESHOLD=2
VERIFICATION_REJECTION_THRESHOLD=2
TRUST_SCORE_INCREMENT=1.0
TRUST_SCORE_PENALTY=2.0
TRUST_SCORE_MIN=-100.0
TRUST_SCORE_MAX=100.0
